{
    "name": "demo/webeid-php",
    "description": "Web eID PHP demo",
    "license": "MIT",
    "authors": [
        {
            "name": "Guido Gröön",
            "role" : "developer"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.5 || ^13"
    },
    "require": {
        "php": ">=8.1",
        "web-eid/web-eid-authtoken-validation-php": "1.3.*",
        "altorouter/altorouter": "^2.0.3",
        "psr/log": "^3.0"
    },
    "autoload": {
        "classmap": ["src"]
    },
    "scripts": {
        "test": "phpunit --no-coverage --display-warnings",
        "test-coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit --coverage-html coverage"
        ]
    }
}
